ppipeline {
    agent any

    environment {
        DOCKER_IMAGE = "flaskapp:v1"
        APP_PATH = "${WORKSPACE}/flask-app-cicd-master/web"
    }

    stages {
        stage('Setup Python') {
            steps {
                echo 'Setting up Python environment'
                sh """
                    python3 -m venv venv
                    source venv/bin/activate
                    pip install -r ${APP_PATH}/requirements.txt
                """
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image'
                sh "docker build -t ${DOCKER_IMAGE} ${APP_PATH}"
            }
        }

        stage('Test') {
            steps {
                echo 'Running Unit Tests'
                sh """
                    source venv/bin/activate
                    pytest ${APP_PATH}/tests --maxfail=1 --disable-warnings
                """
            }
        }

        stage('Integration Tests') {
            steps {
                echo 'Running Integration Tests'
                sh """
                    source venv/bin/activate
                    pytest ${APP_PATH}/integration_tests --maxfail=1 --disable-warnings
                """
            }
        }

        stage('Deployment Preparation') {
            steps {
                echo 'Cleaning old container'
                sh "docker rm -f flaskapp || true"
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Flask App'
                sh "docker run -d --name flaskapp -p 5000:5000 ${DOCKER_IMAGE}"
            }
        }
    }

    post {
        always { echo 'Pipeline finished' }
        success { echo 'Deployment successful!' }
        failure { echo 'Pipeline failed!' }
    }
}